# CVE Insight 환경변수 예시 파일
# 이 파일을 복사해 .env.local 로 만들고 실제 키 값을 채우세요.
#   cp .env.example .env.local
# .env.local 은 .gitignore 되어 커밋되지 않습니다.

# OpenAI API 키 (필수) — 취약점 분석 생성에 사용
OPENAI_API_KEY=

# OpenAI 모델 (선택) — 미설정 시 코드 기본값 사용
OPENAI_MODEL=gpt-4o

# NVD API 키 (선택) — 없으면 rate limit이 낮아지지만 동작은 함
# 발급: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
