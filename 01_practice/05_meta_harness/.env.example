# OpenAI API 설정 (웹툰 작화 - GPT Image 2)
# 이 파일을 복사해 .env 를 만들고 실제 키를 채우세요:
#   cp .env.example .env

# OpenAI API 키 (https://platform.openai.com/api-keys 에서 발급)
OPENAI_API_KEY=sk-proj-여기에_실제_키를_입력하세요

# (선택) 사용할 이미지 생성 모델
OPENAI_IMAGE_MODEL=gpt-image-2

# (선택) 조직 / 프로젝트 ID
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
